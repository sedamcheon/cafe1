{
  "rules": {
    ".read": false,
    ".write": false,
    "cafes": {
      ".read": true,
      ".write": "(auth != null && root.child('admins').child(auth.uid).val() === true) || (!data.exists() && newData.exists())",
      "$cafeId": {
        ".validate": "!newData.exists() || newData.hasChildren(['name', 'location', 'distanceText', 'hours', 'tags'])",
        "name": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
        },
        "location": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 120"
        },
        "distanceText": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
        },
        "distanceMeters": {
          ".validate": "!newData.exists() || newData.isNumber()"
        },
        "hours": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
        },
        "tags": {
          "$tagIndex": {
            ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 40"
          }
        },
        "menus": {
          "$menuId": {
            ".validate": "newData.hasChildren(['name', 'category', 'price', 'updatedAt'])",
            "name": {
              ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
            },
            "category": {
              ".validate": "newData.isString() && (newData.val() === '커피' || newData.val() === '라떼' || newData.val() === '에이드' || newData.val() === '아이스티' || newData.val() === '티' || newData.val() === '주스' || newData.val() === '스무디')"
            },
            "price": {
              ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 50000"
            },
            "updatedAt": {
              ".validate": "newData.isString() && newData.val().length === 10"
            },
            "$other": {
              ".validate": false
            }
          }
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "reports": {
      ".read": "auth != null && root.child('admins').child(auth.uid).val() === true",
      "$reportId": {
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true || (!data.exists() && newData.exists())",
        ".validate": "!newData.exists() || newData.hasChildren(['cafeName', 'drinkName', 'oldPrice', 'newPrice', 'memo', 'createdAt'])",
        "cafeName": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
        },
        "drinkName": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
        },
        "oldPrice": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 50000"
        },
        "newPrice": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 50000"
        },
        "memo": {
          ".validate": "newData.isString() && newData.val().length <= 400"
        },
        "createdAt": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 40"
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "admins": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('admins').child(auth.uid).val() === true)",
        ".write": "auth != null && root.child('admins').child(auth.uid).val() === true",
        ".validate": "newData.isBoolean()"
      }
    }
  }
}
